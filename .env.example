OPENAI_API_KEY=           # Required — OpenAI API key for GPT-4o doc generation + Whisper transcription
NOTION_CLIENT_ID=         # Required for Notion OAuth
NOTION_CLIENT_SECRET=     # Required for Notion OAuth
NOTION_REDIRECT_URI=      # Required for Notion OAuth; must exactly match Notion settings (example: http://localhost:8787/notion/callback)
NOTION_PAGE_ID=           # Optional — Notion page ID to post docs under (share the page with your integration first)
